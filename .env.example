# ─────────────────────────────────────────────────────────────
# MailRite Environment Configuration
# ─────────────────────────────────────────────────────────────

# Composio — Social Auth (handles all OAuth flows)
COMPOSIO_API_KEY=

# Base Chain — x402 Payment Routing
BASE_CHAIN_ID=8453
BASE_PAYMENT_ROUTER_ADDRESS=
X402_SEND_FEE_WEI=1000000000000
X402_STRICT=true

# Poke API — Optional AI Enhancement (fallback to local search)
POKE_API_BASE_URL=
POKE_API_PATH=
POKE_API_KEY=

# SMTP — Fallback Email (if Composio Gmail not connected)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App URL
APP_URL=http://localhost:3000

# Legacy OAuth Client IDs (optional — Composio replaces these)
# GMAIL_CLIENT_ID=
# LINKEDIN_CLIENT_ID=
# TWITTER_CLIENT_ID=
# FACEBOOK_CLIENT_ID=
# SLACK_CLIENT_ID=
# DISCORD_CLIENT_ID=
# HUBSPOT_CLIENT_ID=
# INSTAGRAM_CLIENT_ID=
